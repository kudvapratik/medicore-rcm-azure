{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "medicore-adf-dev"
		},
		"LS_Databricks_Medicore_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'LS_Databricks_Medicore'"
		},
		"LS_ADLS_Medicore_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://medicoreadlsdev.dfs.core.windows.net/"
		},
		"LS_KeyVault_Medicore_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://medicore-kv-dev.vault.azure.net/"
		},
		"LS_SQL_Hospital_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "medicore-sql-dev.database.windows.net"
		},
		"LS_SQL_Hospital_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().db_name}"
		},
		"LS_SQL_Hospital_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Medicoreadmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "medicore-adf-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_Databricks_Medicore_accessToken": {
						"value": "[parameters('LS_Databricks_Medicore_accessToken')]"
					},
					"LS_KeyVault_Medicore_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_Medicore_properties_typeProperties_baseUrl')]"
					},
					"LS_ADLS_Medicore_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Medicore_properties_typeProperties_url')]"
					},
					"LS_SQL_Hospital_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_Hospital_properties_typeProperties_server')]"
					},
					"LS_SQL_Hospital_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_Hospital_properties_typeProperties_database')]"
					},
					"LS_SQL_Hospital_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_Hospital_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}